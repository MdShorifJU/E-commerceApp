<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="520dp"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="2.5dp"
    android:elevation="6dp"
    android:layout_gravity="center"
    android:radius="12dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp">

        <!-- Save badge -->
        <TextView
            android:id="@+id/tvSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save : 1000৳"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:background="#2E7D32"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_margin="8dp"
            android:gravity="center" />

        <!-- Product image -->
        <ImageView
            android:id="@+id/imageItemLaptop"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:layout_below="@id/tvSave"
            android:layout_centerHorizontal="true"
            android:src="@drawable/lenovoimage" />

        <!-- Title -->
        <TextView
            android:id="@+id/titleItemLaptop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/imageItemLaptop"
            android:layout_marginTop="10dp"
            android:text="Lenovo Legion Pro 5"
            android:layout_marginHorizontal="10dp"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Processor -->
        <TextView
            android:id="@+id/laptop_Processor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/titleItemLaptop"
            android:layout_marginTop="6dp"
            android:layout_marginHorizontal="10dp"
            android:text="Processor: AMD Ryzen 7 8745HX"
            android:textSize="13sp" />

        <!-- RAM -->
        <TextView
            android:id="@+id/laptop_Ram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/laptop_Processor"
            android:layout_marginTop="4dp"
            android:layout_marginHorizontal="10dp"
            android:text="RAM: 32GB DDR5 | Storage: 1TB NVMe"
            android:textSize="13sp" />

        <!-- Features -->
        <TextView
            android:id="@+id/laptop_Features"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/laptop_Ram"
            android:layout_marginTop="4dp"
            android:layout_marginHorizontal="10dp"
            android:text="RGB Keyboard, Wi-Fi 7, G-SYNC"
            android:textSize="13sp" />

        <!-- Price section -->
        <LinearLayout
            android:layout_above="@+id/cardViewLay"
            android:layout_marginBottom="10dp"
            android:id="@+id/priceLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp">

            <!-- New price -->
            <TextView
                android:id="@+id/tvNewPrice"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="52,000৳"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#D32F2F"
                android:gravity="start" />

            <!-- Old price -->
            <TextView
                android:id="@+id/tvOldPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="53,000৳"
                android:textSize="14sp"
                android:textColor="#888888"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardViewLay"
            android:layout_alignParentBottom="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            >
            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Buy Now"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:layout_marginHorizontal="10dp"
                android:backgroundTint="#0009ff"
                app:icon="@drawable/cart"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@color/white" />
            <com.google.android.material.button.MaterialButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Add to Cart"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:layout_marginHorizontal="10dp"
                android:backgroundTint="#a4c639"
                app:icon="@drawable/plus"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@color/white" />
        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>
