<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF2F7"
    android:fitsSystemWindows="true"
    tools:context=".CheckOutActivity">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <LinearLayout
                android:id="@+id/headerBanner"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:background="#4A6CF7"
                android:orientation="vertical"
                android:gravity="bottom"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CHECKOUT"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Complete Your Order"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Personal Information"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#222222"
                        android:layout_marginBottom="10dp"/>

                    <EditText
                        android:id="@+id/etUserName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="10dp"
                        android:hint="Enter your full name"
                        android:textSize="16sp"
                        android:textColor="#000000"
                        android:textColorHint="#888888"
                        android:padding="15dp"
                        android:background="@drawable/edittext_bg"
                        android:inputType="textPersonName"/>

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_margin="10dp"
                        android:hint="Enter your email"
                        android:textSize="16sp"
                        android:textColor="#000000"
                        android:textColorHint="#888888"
                        android:padding="15dp"
                        android:background="@drawable/edittext_bg"
                        android:inputType="textEmailAddress"/>

                    <EditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp"
                        android:layout_margin="10dp"
                        android:hint="Enter phone number"
                        android:textSize="16sp"
                        android:textColor="#000000"
                        android:textColorHint="#888888"
                        android:padding="15dp"
                        android:background="@drawable/edittext_bg"
                        android:inputType="phone"/>

                    <EditText
                        android:id="@+id/etAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp"
                        android:layout_margin="10dp"
                        android:hint="Enter your address"
                        android:textSize="16sp"
                        android:textColor="#000000"
                        android:textColorHint="#888888"
                        android:padding="15dp"
                        android:background="@drawable/edittext_bg"
                        android:gravity="top"
                        android:inputType="textMultiLine"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="3dp"
                android:background="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Need Help? Call Us"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#222222"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Available 9AM - 9PM"
                        android:textColor="#666666"
                        android:layout_marginTop="6dp"/>

                    <TextView
                        android:id="@+id/tvPhone1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+880 1711-000001"
                        android:layout_marginTop="10dp"
                        android:textColor="#333333"/>

                    <TextView
                        android:id="@+id/tvPhone2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+880 1811-000002"
                        android:layout_marginTop="6dp"
                        android:textColor="#333333"/>

                    <TextView
                        android:id="@+id/tvPhone3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+880 1911-000003"
                        android:layout_marginTop="6dp"
                        android:textColor="#333333"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button
                android:id="@+id/btnPlaceOrder"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_margin="16dp"
                android:text="PLACE ORDER"
                android:textColor="#FFFFFF"
                android:backgroundTint="#CC2F24"
                android:textStyle="bold"/>
        </LinearLayout>
    </ScrollView>



</androidx.constraintlayout.widget.ConstraintLayout>