<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0F7FA"
    tools:context=".FirstShowProfile">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Title -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your Profile"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingBottom="12dp"/>

                <!-- Profile Image -->
                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="110dp"
                    android:layout_height="110dp"
                    android:layout_gravity="center"
                    android:contentDescription="TODO"
                    android:src="@drawable/plus"
                    android:scaleType="centerCrop"
                    android:background="@drawable/text_border"
                    android:padding="8dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Full Name Label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textStyle="bold"
                    android:paddingTop="12dp"/>

                <!-- Full Name Value -->
                <TextView
                    android:id="@+id/nameUser"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Md Shorif"
                    android:background="@drawable/text_border"
                    android:padding="12dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Phone Label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Phone Number"
                    android:textStyle="bold"
                    android:paddingTop="12dp"/>

                <!-- Phone Value -->
                <TextView
                    android:id="@+id/phoneUser"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="01346658477"
                    android:background="@drawable/text_border"
                    android:padding="12dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Gmail Label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alternative Gmail"
                    android:textStyle="bold"
                    android:paddingTop="12dp"/>

                <!-- Gmail Value -->
                <TextView
                    android:id="@+id/gmailUser"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="20223656641shorif@juniv.edu"
                    android:background="@drawable/text_border"
                    android:padding="12dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Password Label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Old Password"
                    android:textStyle="bold"
                    android:paddingTop="12dp"/>

                <!-- Password Value -->
                <TextView
                    android:id="@+id/passwordUser"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="123456"
                    android:background="@drawable/text_border"
                    android:padding="12dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <Button
                        android:id="@+id/updateBtn"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Update Profile"
                        android:backgroundTint="#00008B"
                        android:textColor="@android:color/white"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/logoutBtn"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Logout"
                        android:backgroundTint="#00008B"
                        android:textColor="@android:color/white"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
